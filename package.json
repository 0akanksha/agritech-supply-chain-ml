{
  "name": "agritech",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n web,ml -c blue,green \"npm run dev --prefix server\" \"npm run dev:ml\"",
    "dev:ml": "cd ml-service && .venv/bin/uvicorn app.main:app --reload --port 8000",
    "build": "tsc -b && vite build",
    "build:all": "npm run build && npm run build --prefix server",
    "start": "npm run start --prefix server",
    "db:push": "npm run db:push --prefix server",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
