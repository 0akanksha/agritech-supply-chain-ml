# Same Neon Postgres database the Express server uses — this service owns its own
# tables in it (weather_observations, ndvi_observations, mandi_prices, etl_runs).
DATABASE_URL=

# Free personal key from https://www.data.gov.in (sign up, then "My Account" -> API keys).
# Used to fetch real mandi prices from the Agmarknet resource.
DATA_GOV_IN_API_KEY=

# Local MLflow tracking store (file-based — no server to run). Relative to ml-service/.
MLFLOW_TRACKING_URI=file:./mlruns
