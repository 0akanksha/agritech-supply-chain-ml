# Same Neon Postgres database the Express server uses — this service owns its own
# tables in it (weather_observations, ndvi_observations, mandi_prices, etl_runs).
DATABASE_URL=

# Free personal key from https://www.data.gov.in (sign up, then "My Account" -> API keys).
# Used to fetch real mandi prices from the Agmarknet resource.
DATA_GOV_IN_API_KEY=

# MLflow tracking store (file-based — no server to run). Relative to ml-service/.
# Deliberately file-based even on Render, not Postgres: MLflow's Postgres backend store
# creates its own tables with no schema option, and Neon's pooled endpoint (the one
# DATABASE_URL above uses) rejects the `search_path` startup parameter needed to keep them
# out of `public` — landing them there would risk the exact `drizzle-kit push` data-loss
# scenario `db.py`'s docstring describes. Net effect: MLflow run *history* resets on every
# Render deploy/cold-start (no persistent disk on the free tier) — an accepted, documented
# limitation. The models actually being served don't reset; see app/models/storage.py.
MLFLOW_TRACKING_URI=file:./mlruns
