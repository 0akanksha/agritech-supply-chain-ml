# Database (Neon serverless Postgres)
DATABASE_URL=

# Auth
JWT_SECRET=
PORT=4000
NODE_ENV=development

# Where the Python ML service (ml-service/) is reachable
ML_SERVICE_URL=http://localhost:8000

# Optional locally (the ML service only enforces this if it's set on ITS side too — see
# ml-service/.env.example). Required in production, where the ML service has a public URL:
# generate one value (e.g. `openssl rand -hex 32`) and set it as INTERNAL_ML_SECRET on BOTH
# services in Render.
INTERNAL_ML_SECRET=

# Seeds an initial admin user on first run (no public admin signup — farmers self-register,
# admin accounts are seeded this way, matching the other apps in this workspace)
ADMIN_EMAIL=
ADMIN_PASSWORD=
