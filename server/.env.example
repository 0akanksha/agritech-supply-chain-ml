# Database (Neon serverless Postgres)
DATABASE_URL=

# Auth
JWT_SECRET=
PORT=4000
NODE_ENV=development

# Where the Python ML service (ml-service/) is reachable. Leave as-is — this is also correct
# in production, where server/src/lib/embeddedMlService.ts spawns the ML service itself on
# 127.0.0.1:8000 rather than it running as a separate service (see render.yaml's
# EMBEDDED_ML_SERVICE — production-only, never set this locally).
ML_SERVICE_URL=http://localhost:8000

# Seeds an initial admin user on first run (no public admin signup — farmers self-register,
# admin accounts are seeded this way, matching the other apps in this workspace)
ADMIN_EMAIL=
ADMIN_PASSWORD=
